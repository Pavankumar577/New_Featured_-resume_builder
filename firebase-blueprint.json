{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account and profile data",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "User unique identifier matching auth UID"
        },
        "email": {
          "type": "string",
          "description": "Primary email address of the user"
        },
        "displayName": {
          "type": "string",
          "description": "Display name of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Profile creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last profile update timestamp"
        }
      },
      "required": ["userId", "email"]
    },
    "Resume": {
      "title": "Resume",
      "description": "A customized professional resume",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the resume document"
        },
        "userId": {
          "type": "string",
          "description": "The UID of the owner"
        },
        "title": {
          "type": "string",
          "description": "Title/Name of this resume revision"
        },
        "personalInfo": {
          "type": "object",
          "description": "Contact info and role summary"
        },
        "experience": {
          "type": "array",
          "description": "List of work experience items"
        },
        "education": {
          "type": "array",
          "description": "List of education records"
        },
        "skills": {
          "type": "array",
          "description": "List of skills"
        },
        "projects": {
          "type": "array",
          "description": "List of projects"
        },
        "atsType": {
          "type": "string",
          "description": "Selected ATS platform simulation constraint"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["id", "userId", "title"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection indexed by Auth UID"
    },
    "resumes/{resumeId}": {
      "schema": "Resume",
      "description": "Resume records and revisions saved in real-time"
    }
  }
}
